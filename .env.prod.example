# ==========================================================================
# Пример продакшен-конфигурации. Скопируйте в .env.prod и заполните значения:
#   cp .env.prod.example .env.prod
# Запуск:
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
# НЕ коммитьте .env.prod в git!
# ==========================================================================

# --- Домен (без схемы). Нужны A-записи: DOMAIN, api.DOMAIN, s3.DOMAIN ---
DOMAIN=nskfolktheatre.ru
# Публичный URL сайта (для sitemap.xml). Обычно https://DOMAIN
# FRONTEND_BASE_URL=https://nskfolktheatre.ru

# --- Django ---
# Сгенерируйте длинный случайный ключ, например:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=2-bOtFl9j2FhVI4JVIN3KhCx9XyPrqOeiC66LtQeSxu-JUbx3QxqurK3kT0EjeDBUZRufoRWpocxmgpFb3jnVg

# --- PostgreSQL ---
DATABASE_NAME=antrakt
DATABASE_USER=antrakt
DATABASE_PASSWORD=antrakt_nnt_1!

# --- MinIO (S3-хранилище изображений) ---
MINIO_ACCESS_KEY=nnt_admin_minio
MINIO_SECRET_KEY=nnt_admin_492_minio
MINIO_BUCKET_NAME=antrakt-images

# Заглушка вместо отсутствующей основной фотографии (полный URL к zaglushka.jpg).
# Используется backend (PLACEHOLDER_IMAGE_URL) и frontend (через compose build-arg).
PLACEHOLDER_IMAGE_URL=https://s3.nskfolktheatre.ru/antrakt-images/zaglushka.jpg

# --- Почта (Яндекс SMTP): нужна для кода регистрации и восстановления пароля ---
# Пароль приложения создаётся в Яндекс ID -> Безопасность -> Пароли приложений -> Почта (SMTP).
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=NP1R777@yandex.ru
EMAIL_HOST_PASSWORD=vloscddlwlypenvr
DEFAULT_FROM_EMAIL=NP1R777@yandex.ru

# --- Парсер отзывов ВК (необязательно). Хотя бы одно из двух: ---
# HTML: cookie remixsid из браузера, где вы вошли во ВКонтакте.
VK_SESSION_COOKIE=
# ЛИБО API: сервисный ключ вашего приложения dev.vk.com.
VK_ACCESS_TOKEN=bf4d5ac1bf4d5ac1bf4d5ac149bc0f6151bbf4dbf4d5ac1d5029410521aaf8cc0d6f6ea
VK_GROUP_DOMAIN=tc_antrakt
